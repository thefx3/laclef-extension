{
  "manifest_version": 3,
  "name": "La CLEF Assistant",
  "description": "Automatisations ANIAPPS et billetterie La CLEF.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://laclef.aniapp.fr/*",
    "https://billetterie.laclef.asso.fr/*",
    "https://docs.google.com/*"
  ],
  "action": {
    "default_title": "La CLEF Assistant",
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/templates/*.docx"
      ],
      "matches": [
        "https://laclef.aniapp.fr/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://laclef.aniapp.fr/admin/*"
      ],
      "css": [
        "src/styles/content.css"
      ],
      "js": [
        "src/shared/fx-utils.js",
        "src/content/aniapps-flce.js",
        "src/content/aniapps-paniers.js",
        "src/content/aniapps-sepa.js",
        "src/content/aniapps-programmations.js",
        "src/content/aniapps-music-converter.js",
        "src/content/aniapps-music-members.js",
        "src/content/aniapps-compare-programmations.js",
        "src/content/aniapps-export-tarifs.js",
        "src/content/aniapps-agenda-live.js",
        "src/content/billetterie-autofill.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://docs.google.com/spreadsheets/*"
      ],
      "css": [
        "src/styles/content.css"
      ],
      "js": [
        "src/shared/fx-utils.js",
        "src/content/google-sheets-music-collector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://billetterie.laclef.asso.fr/*"
      ],
      "css": [
        "src/styles/content.css"
      ],
      "js": [
        "src/shared/fx-utils.js",
        "src/content/billetterie-autofill.js"
      ],
      "run_at": "document_idle"
    },
    {
    "matches": ["https://laclef.aniapp.fr/admin/families/*/address_proofs/*/edit*"],
    "js": [
      "src/content/aniapps-address-proof-email.js"
    ],
    "run_at": "document_idle"
    }
  ]
}
